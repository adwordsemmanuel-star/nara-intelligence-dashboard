<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /consulta/premium/
  
  # Si la ruta es /admin o /admin/ (sin .html), servir admin.html
  RewriteRule ^admin/?$ admin.html [L]

  # Si el archivo o carpeta física existe, cargarlo directamente
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Todo lo demás al index.html
  RewriteRule ^(.*)$ index.html [L]
</IfModule>
