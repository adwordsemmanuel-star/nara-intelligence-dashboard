---
interface Props {
  title: string;
  price?: string;
  description: string;
  features: string[];
  isFeatured?: boolean;
  ctaText: string;
}

const { title, price, description, features, isFeatured = false, ctaText } = Astro.props;
---

<div class:list={[
  "relative p-8 rounded-[2.5rem] flex flex-col h-full transition-all duration-500",
  isFeatured 
    ? "bg-white border-2 border-nara-gold shadow-[0_20px_50px_rgba(209,160,107,0.15)] scale-105 z-10" 
    : "bg-white border border-gray-100 hover:shadow-xl"
]}>
  {isFeatured && (
    <span class="absolute -top-4 left-1/2 -translate-x-1/2 bg-nara-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest shadow-md">
      Más Recomendado
    </span>
  )}

  <h3 class="text-2xl font-serif mb-2 text-nara-navy">
    {title}
  </h3>
  
  {price && (
    <div class="flex items-baseline gap-1 mb-4">
      <span class:list={["text-3xl font-bold", isFeatured ? "text-nara-gold" : "text-nara-navy"]}>{price}</span>
      <span class="text-sm text-gray-500">MXN</span>
    </div>
  )}

  <p class="text-sm mb-8 leading-relaxed text-gray-500">
    {description}
  </p>

  <ul class="space-y-4 mb-10 flex-grow">
    {features.map((feature) => (
      <li class="flex items-start gap-3 text-sm">
        <svg class:list={["w-5 h-5 flex-shrink-0", isFeatured ? "text-nara-gold" : "text-nara-pink"]} fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <span class="text-gray-600">{feature}</span>
      </li>
    ))}
  </ul>

  <a 
    href="#contacto" 
    class:list={[
      "block w-full py-4 rounded-full font-bold text-center transition-all",
      isFeatured 
        ? "bg-nara-gold text-white hover:bg-opacity-90 shadow-lg" 
        : "bg-nara-gradient text-white hover:shadow-lg active:scale-95"
    ]}
  >
    {ctaText}
  </a>
</div>

