---
import MainLayout from './MainLayout.astro';
import GradientButton from '../components/ui/GradientButton.astro';
import { SERVICES, SPECIALISTS } from '../data/nara-config';

interface Props {
  serviceId: 'pareja' | 'individual' | 'infantil';
}

const { serviceId } = Astro.props;
const service = SERVICES[serviceId];

// Get relevant specialists data
const relevantSpecialists = SPECIALISTS.filter(sp => service.specialists.includes(sp.id));

const WHATSAPP = "https://wa.me/5219983935293";
const BASE = import.meta.env.BASE_URL;
---

<MainLayout 
  title={`${service.title} | NARA Psychology`}
  description={service.description}>
  
  <!-- Hero Section -->
  <section class="pt-32 pb-20 bg-white">
    <div class="max-w-7xl mx-auto px-8 sm:px-12 lg:px-20">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-10">
          <span class="text-xs font-bold text-nara-gold uppercase tracking-[0.3em]">Programa de Especialidad</span>
          <h1 class="text-6xl lg:text-[85px] font-serif leading-[1.05] text-nara-navy font-bold tracking-tight">
            {service.title.split(' ').map((word, i) => (
                i === 1 ? <><span class="italic text-nara-pink font-medium">{word}</span> </> : word + ' '
            ))}
          </h1>
          <p class="text-xl lg:text-2xl text-gray-800 leading-relaxed max-w-xl font-medium">
            {service.description}
          </p>
          <div class="pt-4">
            <GradientButton href={WHATSAPP}>
              SOLICITAR DISPONIBILIDAD
            </GradientButton>
          </div>
        </div>
        
        <div class="relative group">
          <div class="relative aspect-[4/5] rounded-[3rem] overflow-hidden shadow-2xl border border-white">
            <img 
              src={`${BASE}images/${serviceId}-hero.png`} 
              alt={service.title} 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              onerror="this.src='/images/pareja-premium.png'"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section (Contextual) -->
  <section class="py-24 bg-gray-50 border-y border-gray-100">
    <div class="max-w-7xl mx-auto px-8 sm:px-12 lg:px-20 text-center">
      <h2 class="text-4xl font-serif text-nara-navy mb-16">Inversión en tu Proceso</h2>
      
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {Object.entries(service.pricing).map(([key, item]) => (
          <div class="bg-white p-10 rounded-[3rem] border border-gray-100 shadow-sm relative overflow-hidden group">
            {key === 'director' && <div class="absolute top-4 right-4 bg-nara-gold/10 text-nara-gold text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest">Nivel Director</div>}
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">{item.label || 'Sesión Individual'}</p>
            <h3 class="text-2xl font-bold text-nara-navy mb-4">{item.name}</h3>
            <div class="text-5xl font-bold font-serif text-nara-navy mb-6">
              ${item.price} <span class="text-sm font-sans font-normal text-gray-400">/ sesión</span>
            </div>
            
            {item.packagePrice && (
              <div class="mt-6 pt-6 border-t border-dashed border-gray-100">
                <p class="text-sm font-bold text-nara-aqua uppercase tracking-widest mb-2">Paquete Recomendado</p>
                <div class="text-2xl font-bold text-nara-navy">
                  ${item.packagePrice} <span class="text-xs text-gray-400">por {item.packageSessions} sesiones</span>
                </div>
                <p class="text-[10px] text-gray-400 mt-2">Flexibilidad: 50% en 1ª sesión, 50% en 3ª sesión.</p>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Specialists Section (Only relevant ones) -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-8 sm:px-12 lg:px-20 text-center">
      <h2 class="text-4xl font-serif text-nara-navy mb-16">Especialistas en {service.title}</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10 justify-center">
        {relevantSpecialists.map(sp => (
          <div class="bg-white rounded-[2.5rem] border border-gray-100 overflow-hidden shadow-sm hover:shadow-xl transition-all p-8">
            <h3 class="font-serif font-bold text-2xl text-nara-navy">{sp.name}</h3>
            <p class="text-xs font-bold text-nara-gold uppercase tracking-widest mt-1 mb-4">{sp.role}</p>
            <a href={WHATSAPP} class="inline-block w-full py-3 bg-gray-50 rounded-xl text-xs font-bold text-nara-navy uppercase tracking-widest hover:bg-nara-gold hover:text-white transition-all">
              Consultar Agenda
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-32 bg-nara-navy text-white text-center">
    <div class="max-w-4xl mx-auto px-8 space-y-10">
      <h2 class="text-4xl lg:text-6xl font-serif">¿Iniciamos tu proceso?</h2>
      <p class="text-xl text-white/70 leading-relaxed">
        Agenda hoy mismo y da el primer paso hacia una vida más plena y consciente.
      </p>
      <div class="flex justify-center">
        <GradientButton href={WHATSAPP}>
          AGENDAR POR WHATSAPP
        </GradientButton>
      </div>
    </div>
  </section>

</MainLayout>
